{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["./hardhat.config.ts", "./contracts/**/*.ts", "./test/**/*.ts", "./deploy/**/*.ts", "./tasks/**/*.ts"],
  "exclude": ["node_modules", "artifacts", "cache", "dist", "typechain-types"]
}
